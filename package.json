{
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "rm -rf public/dist && mprocs",
    "build": "unocss && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier \"**/*.{css,html,json,md,mjs,ts,yml}\" --write",
    "format:check": "prettier \"**/*.{css,html,json,md,mjs,ts,yml}\" --check",
    "test:types": "tsc --noEmit"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@csstools/postcss-global-data": "^4.0.0",
    "@iconify-json/dinkie-icons": "^1.2.0",
    "@types/node": "^26.1.0",
    "@unocss/cli": "^66.7.4",
    "@unocss/core": "^66.7.4",
    "@unocss/preset-icons": "^66.7.4",
    "@unocss/preset-wind4": "^66.7.4",
    "eslint": "^10.6.0",
    "mprocs": "^0.9.6",
    "ofetch": "2.0.0-alpha.3",
    "postcss": "^8.5.16",
    "postcss-custom-media": "^12.0.1",
    "postcss-nesting": "^14.0.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "unocss": "^66.7.4",
    "vite": "^8.1.3",
    "vite-plugin-full-reload": "^1.2.0"
