{
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "dev": "rm -rf public/dist && mprocs",
    "build": "unocss && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier \"**/*.{css,html,json,md,mjs,ts,yml}\" --write",
    "format:check": "prettier \"**/*.{css,html,json,md,mjs,ts,yml}\" --check",
    "test:types": "tsc --noEmit"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@csstools/postcss-global-data": "^4.0.0",
    "@types/node": "^25.9.3",
    "@unocss/cli": "^66.7.0",
    "@unocss/core": "^66.7.0",
    "@unocss/preset-wind4": "^66.7.0",
    "eslint": "^10.4.1",
    "mprocs": "^0.9.6",
    "postcss": "^8.5.15",
    "postcss-custom-media": "^12.0.1",
    "postcss-nesting": "^14.0.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "unocss": "^66.7.0",
    "vite": "^8.0.16",
    "vite-plugin-full-reload": "^1.2.0"
  }
}
